# Local development only. On Render these are set via render.yaml / the dashboard.
# Run locally with:  node --env-file=.env dist/index.js

PORT=3000

# Endpoint access token (strongly recommended). Clients must send:
#   Authorization: Bearer <this value>
# Leave empty to run the endpoint OPEN (not recommended).
MCP_AUTH_TOKEN=change-me-to-a-long-random-string

# Per-operation access control. Each flag enables one SQL operation; a statement
# is accepted only if its operation is enabled below. Anything else (CREATE,
# DROP, ALTER, TRUNCATE, ...) is always rejected. Safe default: read-only.
MYSQL_ALLOW_SELECT=true
MYSQL_ALLOW_INSERT=false
MYSQL_ALLOW_UPDATE=true
MYSQL_ALLOW_DELETE=false

# Other safety limits
MYSQL_MAX_ROWS=1000
MYSQL_CONNECT_TIMEOUT_MS=10000

# Optional: comma-separated allowlist of database hosts clients may connect to.
# Empty = any host is allowed.
# ALLOWED_DB_HOSTS=db1.example.com,db2.example.com
